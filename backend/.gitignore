############################
# TypeScript Compiled Output
############################

# Strapi v5 generates .js files alongside .ts during development
# These are build artifacts - source of truth is the .ts file
src/db/schema.js
src/db/client.js
src/db/repositories/*.js
src/db/__tests__/test-db-helper.js
src/utils/*.js

# Strapi v5 compiles TypeScript to these directories (not in src/)
# Only appears when API/services are converted to TS
/api/
/db/