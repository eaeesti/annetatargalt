{
  "name": "annetatargalt",
  "version": "2.0.0",
  "description": "Anneta Targalt donation platform",
  "license": "AGPL-3.0-or-later",
  "author": {
    "name": "Andri Soone"
  },
  "scripts": {
    "clear": "cd frontend && rm -rf .next && rm -rf cache",
    "develop": "yarn clear && concurrently \"cd frontend && yarn develop\" \"cd backend && yarn develop\" \"cd admin && npm run dev\"",
    "setup:frontend": "cd frontend && yarn",
    "setup:backend": "cd backend && yarn",
    "setup:admin": "cd admin && npm install",
    "setup": "yarn install && yarn setup:frontend && yarn setup:backend && yarn setup:admin",
    "generate-types": "node scripts/generate-strapi-types.mjs"
  },
  "dependencies": {
    "@strapi/provider-email-nodemailer": "5.37.1",
    "concurrently": "^7.6.0",
    "nodemailer": "^6.9.16"
  },
  "devDependencies": {
    "@strapi/typescript-utils": "^5.38.0"
  }
}
